# MongoDB Atlas connection string (required for production/deployment)
MONGODB_ATLAS_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/opportunity_tracker?retryWrites=true&w=majority&appName=Tracktern

# Optional local fallback for development only
MONGO_URI=mongodb://localhost:27017/opportunity_tracker

LLM_API_KEY=your_llm_api_key
PORT=3000
SESSION_SECRET=replace_with_secure_random_secret
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
